<Window x:Class="SmartSecurityIoT.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Security IoT"
        Height="720"
        Width="1280"
        Background="#111827">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <Border Background="#1F2937"
                CornerRadius="20"
                Padding="16"
                Margin="0,0,20,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Ellipse Width="14" Height="14" Fill="LimeGreen"/>
                    <TextBlock Text=" RTSP CONNECTÉ"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="10,0,30,0"/>

                    <Ellipse Width="14" Height="14" Fill="Red"/>
                    <TextBlock Text=" PLC DÉCONNECTÉ"
                               Foreground="White"
                               FontWeight="Bold"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Background="#0F172A"
                        CornerRadius="16">
                    <Grid>
                        <TextBlock Text="Flux Vidéo"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="26"
                                   FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <Button Grid.Row="2"
                        Content="Tester Reconnaissance (Webcam PC)"
                        Height="48"
                        Margin="0,20,0,0"
                        FontWeight="Bold"/>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Background="#1F2937"
                CornerRadius="20"
                Padding="16">

            <StackPanel>
                <TextBlock Text="Historique Détections"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,16"/>

                <Border Background="#111827"
                        CornerRadius="12"
                        Padding="10"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="BENAMAR Othmane"
                                   Foreground="LimeGreen"
                                   FontWeight="Bold"/>
                        <TextBlock Text="20/05/2026 11:30"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="#111827"
                        CornerRadius="12"
                        Padding="10">
                    <StackPanel>
                        <TextBlock Text="Visage inconnu détecté"
                                   Foreground="Orange"
                                   FontWeight="Bold"/>
                        <TextBlock Text="20/05/2026 11:35"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
