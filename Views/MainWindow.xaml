<Window x:Class="SmartSecurityIoT.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartSecurityIoT.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Smart Security IoT"
        Height="720"
        Width="1280"
        Background="#111827"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <!-- Video Panel -->
        <Border Background="#1F2937"
                CornerRadius="20"
                Padding="16"
                Margin="0,0,20,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status Indicators -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Ellipse Width="14" Height="14" Fill="{Binding RtspStatusColor}"/>
                    <TextBlock Text="{Binding RtspStatusText}"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="10,0,30,0"/>

                    <Ellipse Width="14" Height="14" Fill="{Binding PlcStatusColor}"/>
                    <TextBlock Text="{Binding PlcStatusText}"
                               Foreground="White"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- Video Feed -->
                <Border Grid.Row="1"
                        Background="#0F172A"
                        CornerRadius="16">
                    <Grid>
                        <Image Source="{Binding CurrentFrame}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <TextBlock Text="Flux Vidéo — En attente de connexion"
                                   Foreground="#4B5563"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding CurrentFrame, Converter={StaticResource NullToVisibleConverter}, FallbackValue=Visible}"/>
                    </Grid>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Connecter RTSP"
                            Command="{Binding ConnectRtspCommand}"
                            Height="42"
                            Padding="20,0"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="Connecter PLC"
                            Command="{Binding ConnectPlcCommand}"
                            Height="42"
                            Padding="20,0"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Background="#7C3AED"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="{Binding IsTestMode, Converter={StaticResource TestModeButtonTextConverter}, FallbackValue='Mode Test (Webcam)'}"
                            Command="{Binding ToggleTestModeCommand}"
                            Height="42"
                            Padding="20,0"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Background="#D97706"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="Reconnaissance"
                            Command="{Binding RecognizeFaceCommand}"
                            Height="42"
                            Padding="20,0"
                            FontWeight="Bold"
                            Background="#059669"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Detection History Panel -->
        <Border Grid.Column="1"
                Background="#1F2937"
                CornerRadius="20"
                Padding="16">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Historique Détections"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,16"/>

                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding DetectionHistory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#111827"
                                    CornerRadius="12"
                                    Padding="10"
                                    Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{Binding StatusColor}"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Time}"
                                               Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="#1F2937"
                CornerRadius="10"
                Padding="16,8"
                Margin="0,16,0,0">
            <TextBlock Text="{Binding Status}"
                       Foreground="#9CA3AF"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
