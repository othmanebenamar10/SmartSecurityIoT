<Window x:Class="SmartSecurityIoT.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SmartSecurityIoT.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Smart Security IoT"
        Height="780"
        Width="1280"
        Background="#111827"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="1.2*" />
        </Grid.ColumnDefinitions>

        <!-- Video Panel -->
        <Border Background="#1F2937"
                CornerRadius="20"
                Padding="16"
                Margin="0,0,20,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Status Indicators -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Ellipse Width="14" Height="14" Fill="{Binding RtspStatusColor}"/>
                    <TextBlock Text="{Binding RtspStatusText}"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="10,0,30,0"/>

                    <Ellipse Width="14" Height="14" Fill="{Binding PlcStatusColor}"/>
                    <TextBlock Text="{Binding PlcStatusText}"
                               Foreground="White"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- Video Feed -->
                <Border Grid.Row="1"
                        Background="#0F172A"
                        CornerRadius="16">
                    <Grid>
                        <Image Source="{Binding CurrentFrame}"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>

                        <TextBlock Text="Flux Vidéo — En attente de connexion"
                                   Foreground="#4B5563"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Visibility="{Binding CurrentFrame, Converter={StaticResource NullToVisibleConverter}, FallbackValue=Visible}"/>
                    </Grid>
                </Border>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Connecter RTSP"
                            Command="{Binding ConnectRtspCommand}"
                            Height="42"
                            Padding="20,0"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="Connecter PLC"
                            Command="{Binding ConnectPlcCommand}"
                            Height="42"
                            Padding="20,0"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Background="#7C3AED"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="{Binding IsTestMode, Converter={StaticResource TestModeButtonTextConverter}, FallbackValue='Mode Test (Webcam)'}"
                            Command="{Binding ToggleTestModeCommand}"
                            Height="42"
                            Padding="20,0"
                            Margin="0,0,10,0"
                            FontWeight="Bold"
                            Background="#D97706"
                            Foreground="White"
                            BorderThickness="0"/>

                    <Button Content="Reconnaissance"
                            Command="{Binding RecognizeFaceCommand}"
                            Height="42"
                            Padding="20,0"
                            FontWeight="Bold"
                            Background="#059669"
                            Foreground="White"
                            BorderThickness="0"/>
                </StackPanel>

                <!-- Face Registration -->
                <Border Grid.Row="3"
                        Background="#0F172A"
                        CornerRadius="12"
                        Padding="12"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Enregistrer un visage"
                                   Foreground="#9CA3AF"
                                   FontWeight="Bold"
                                   FontSize="14"
                                   Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding NewUserName, UpdateSourceTrigger=PropertyChanged}"
                                     Width="250"
                                     Height="38"
                                     Padding="10,8"
                                     FontSize="14"
                                     Background="#1F2937"
                                     Foreground="White"
                                     BorderBrush="#374151"
                                     BorderThickness="1"/>

                            <Button Content="Enregistrer Visage"
                                    Command="{Binding RegisterFaceCommand}"
                                    Height="38"
                                    Padding="16,0"
                                    Margin="10,0,0,0"
                                    FontWeight="Bold"
                                    Background="#2563EB"
                                    Foreground="White"
                                    BorderThickness="0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Right Panel -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Registered Users Panel -->
            <Border Background="#1F2937"
                    CornerRadius="20"
                    Padding="16"
                    Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Utilisateurs Enregistrés"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                        <TextBlock Text="{Binding RegisteredUsersCount, StringFormat=' ({0})'}"
                                   Foreground="#9CA3AF"
                                   FontSize="18"
                                   FontWeight="Bold"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding RegisteredUsers}"
                                  MaxHeight="150">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#111827"
                                        CornerRadius="8"
                                        Padding="10,6"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <TextBlock Text="{Binding}"
                                                   Foreground="LimeGreen"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <Button Content="X"
                                                Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                HorizontalAlignment="Right"
                                                Width="28" Height="28"
                                                FontWeight="Bold"
                                                Background="#EF4444"
                                                Foreground="White"
                                                BorderThickness="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Detection History Panel -->
            <Border Grid.Row="1"
                    Background="#1F2937"
                    CornerRadius="20"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Historique Détections"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding DetectionHistory}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#111827"
                                            CornerRadius="10"
                                            Padding="10"
                                            Margin="0,0,0,8">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{Binding StatusColor}"
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Time}"
                                                       Foreground="#9CA3AF"
                                                       FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="#1F2937"
                CornerRadius="10"
                Padding="16,8"
                Margin="0,16,0,0">
            <TextBlock Text="{Binding Status}"
                       Foreground="#9CA3AF"
                       FontSize="14"
                       FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
