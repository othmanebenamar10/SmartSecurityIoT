# Smart Security IoT configuration (example)

# App
SSIOT_ENV=dev
SSIOT_DB_PATH=app_data/smart_security_iot.db
SSIOT_LOG_DIR=logs

# Modes
SSIOT_MODE=test   # test | real

# Camera
RTSP_URL=0        # "0" for local webcam, or rtsp://user:pass@ip:554/...
CAMERA_FPS_TARGET=15

# Security
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMeNow!
SESSION_TIMEOUT_MIN=20
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MIN=10

# Face recognition thresholds
FR_THRESHOLD=0.40
MULTIFRAME_REQUIRED=5
CONFIDENCE_MIN=0.70

# PLC (Siemens LOGO! V8 via Modbus TCP)
PLC_IP=192.168.1.50
PLC_PORT=502
PLC_LIGHT_COIL=1
LIGHT_ON_SECONDS=15

# Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=
